# AstraNotes configuration (copy to `.env` or export these in your shell).
# Every value is OPTIONAL in development: if unset, AstraNotes generates a key
# into the git-ignored instance/ directory on first run. Set them explicitly in
# production so the keys are stable across restarts.

# Fernet key (base64, 32 bytes) used to encrypt SecureNote bodies at rest.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ASTRANOTES_ENCRYPTION_KEY=

# Flask session signing secret. Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
ASTRANOTES_SECRET_KEY=

# Optional SHA-256 hex of the passphrase that gates SecureNote unlock.
# Generate with:  python -c "import hashlib; print(hashlib.sha256(b'your passphrase').hexdigest())"
# Leave blank to leave the unlock gate open (single-user local default).
ASTRANOTES_PASSPHRASE_SHA256=

# Where the SQLite database file lives. Defaults to instance/astranotes.db.
ASTRANOTES_DB_PATH=
